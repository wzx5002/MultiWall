<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:MultiWall.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="MultiWall.Views.MonitorSettingsView"
             x:DataType="models:MonitorInfo"
             d:DesignWidth="800" d:DesignHeight="600">

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="20,16">

            <!-- Header -->
            <TextBlock Text="{Binding DisplayName}"
                       FontSize="22" FontWeight="Bold"/>

            <!-- Preview -->
            <Border CornerRadius="8" ClipToBounds="True"
                    Background="{DynamicResource SystemControlBackgroundAltLowBrush}"
                    Height="240"
                    HorizontalAlignment="Left" Width="480">
                <Image Source="{Binding Preview}"
                       Stretch="UniformToFill"
                       Width="480" Height="240"/>
            </Border>

            <!-- Monitor Info -->
            <Border Padding="14" CornerRadius="6"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{DynamicResource Label.Resolution}" FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text="{Binding BoundsText}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{DynamicResource Label.CurrentWallpaper}" FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text="{Binding WallpaperPath}"
                                   FontSize="13" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Mode selector -->
            <Border Padding="14" CornerRadius="6"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="Mode" FontSize="14" FontWeight="Bold"/>
                    <ComboBox SelectedIndex="{Binding ModeIndex}"
                              Width="200" Height="30"
                              VerticalAlignment="Center">
                        <ComboBox.Items>
                            <x:String>Single Image</x:String>
                            <x:String>Slideshow</x:String>
                        </ComboBox.Items>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Single Image panel -->
            <Border Padding="14" CornerRadius="6"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    IsVisible="{Binding !IsSlideshow}">
                <StackPanel Spacing="10">
                    <TextBlock Text="{DynamicResource Label.SingleImage}"
                               FontSize="15" FontWeight="Bold"/>
                    <TextBlock Text="{Binding WallpaperPath}"
                               FontSize="12" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <Button Content="{DynamicResource Button.Browse}"
                            Command="{ReflectionBinding $parent[Window].DataContext.BrowseSingleImageCommand}"
                            HorizontalAlignment="Left" Padding="14,6"
                            CornerRadius="4"/>
                </StackPanel>
            </Border>

            <!-- Slideshow panel -->
            <Border Padding="14" CornerRadius="6"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    IsVisible="{Binding IsSlideshow}">
                <StackPanel Spacing="10">
                    <TextBlock Text="{DynamicResource Label.Slideshow}"
                               FontSize="15" FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Folder:" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
                        <TextBlock Text="{Binding SlideshowImages.Count, StringFormat='{}{0} images loaded'}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Content="{DynamicResource Button.SlideshowFolder}"
                            Command="{ReflectionBinding $parent[Window].DataContext.BrowseSlideshowFolderCommand}"
                            HorizontalAlignment="Left" Padding="14,6"
                            CornerRadius="4"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{DynamicResource Label.Interval}" FontSize="13" VerticalAlignment="Center"/>
                        <TextBox Text="{ReflectionBinding $parent[Window].DataContext.SlideshowInterval}"
                                 Width="60" Height="28"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Label.Seconds}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Clear -->
            <Button Content="{DynamicResource Button.Clear}"
                    Command="{ReflectionBinding $parent[Window].DataContext.ClearCurrentWallpaperCommand}"
                    HorizontalAlignment="Left" Padding="14,6"
                    CornerRadius="4"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
